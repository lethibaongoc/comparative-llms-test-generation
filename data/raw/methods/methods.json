    "class": "AbstractCategoryItemRenderer",
    "method": "getLegendItems",
    "source": "public LegendItemCollection getLegendItems() {\n  LegendItemCollection result = new LegendItemCollection();\n  if (this.plot == null) return result;\n  int index = this.plot.getIndexOf(this);\n  CategoryDataset dataset = this.plot.getDataset(index);\n  if (dataset == null) return result;\n  for (int i = 0; i < dataset.getRowCount(); i++) {\n    if (isSeriesVisibleInLegend(i)) result.add(getLegendItem(index, i));\n  }\n  return result;\n}",
